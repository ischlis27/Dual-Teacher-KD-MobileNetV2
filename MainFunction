def describe_model(model, role: str):
    try:
        total = int(model.count_params())
    except Exception:
        total = -1
    trainable = int(np.sum([np.prod(v.shape) for v in model.trainable_variables]))
    print(f"{role}: name={model.name} | params={total:,} | trainable_params={trainable:,}")


class TimeHistory(tf.keras.callbacks.Callback):
    def on_train_begin(self, logs=None):
        self.times = []

    def on_epoch_begin(self, epoch, logs=None):
        self._t0 = time.time()

    def on_epoch_end(self, epoch, logs=None):
        self.times.append(time.time() - self._t0)


class LRLogToHistory(tf.keras.callbacks.Callback):
    def on_epoch_end(self, epoch, logs=None):
        if logs is None:
            return
        opt = getattr(self.model, "optimizer", None)
        if opt is None:
            return
        try:
            logs["learning_rate"] = float(tf.keras.backend.get_value(opt.learning_rate))
        except Exception:
            pass


class EpochSetter(tf.keras.callbacks.Callback):
    """Sets model.epoch_var each epoch (for alpha/beta warmup in distillers)."""
    def on_epoch_begin(self, epoch, logs=None):
        if hasattr(self.model, "epoch_var") and isinstance(self.model.epoch_var, tf.Variable):
            self.model.epoch_var.assign(epoch)


class BestStudentSaver(tf.keras.callbacks.Callback):
    """Save BEST-val student weights (works for Baseline / Control / Proposed)."""
    def __init__(self, student_model, path, monitor="val_acc", mode="max"):
        super().__init__()
        self.student_model = student_model
        self.path = path
        self.monitor = monitor
        self.mode = mode
        self.best = -np.inf if mode == "max" else np.inf

    def on_epoch_end(self, epoch, logs=None):
        if logs is None or self.monitor not in logs:
            return
        val = float(logs[self.monitor])
        improved = (val > self.best) if self.mode == "max" else (val < self.best)
        if improved:
            self.best = val
            self.student_model.save_weights(self.path)
            print(f"[BestStudentSaver] Epoch={epoch+1} {self.monitor}={val:.4f} -> Saved: {self.path}")


