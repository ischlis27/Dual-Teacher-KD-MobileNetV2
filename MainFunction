def choose_mobilenetv2_bottleneck_taps(backbone: keras.Model, mode: str, num_taps: int):
    candidates = [l.name for l in backbone.layers if l.name.endswith("project_BN")]
    if not candidates:
        raise RuntimeError("No MobileNetV2 '*project_BN' layers found.")

    def pick(frac: float) -> str:
        idx = int(frac * (len(candidates) - 1))
        idx = max(0, min(idx, len(candidates) - 1))
        return candidates[idx]

    if mode == "late":
        taps = [pick(0.85), pick(0.95)]
    elif mode == "mixed":
        taps = [pick(0.50), pick(0.90)]
    elif mode == "early":
        taps = [pick(0.20), pick(0.35)]
    else:
        raise ValueError("Tap Mode Must Be 'early' | 'mixed' | 'late'.")

    return taps[:num_taps]


def build_resnet50_logits_teacher(num_classes: int):
    weights = "imagenet" if CONFIG["teacher_imagenet_init"] else None
    backbone = keras.applications.ResNet50(
        include_top=False,
        weights=weights,
        input_shape=(*CONFIG["input_size"], 3),
    )
    backbone.trainable = False  # head-only for speed

    inputs = keras.Input(shape=(*CONFIG["input_size"], 3))
    x = keras.applications.resnet.preprocess_input(inputs)
    feat = backbone(x, training=False)
    x = layers.GlobalAveragePooling2D()(feat)
    x = layers.Dense(512, activation="relu")(x)
    logits = layers.Dense(num_classes, name="logits", dtype="float32")(x)
    return keras.Model(inputs, logits, name="teacher_resnet50_logits")


class StudentTapModel(tf.keras.Model):
    """
    Subclassed Student Model that propagates `training` to backbone.
    (This block is indentation-safe: 4 spaces everywhere.)
    """
    def __init__(self, num_classes: int, tap_layer_names, imagenet_init: bool, alpha: float, freeze_bn: bool):
        super().__init__(name="student_mobilenetv2_taps")

        weights = "imagenet" if imagenet_init else None
        backbone = keras.applications.MobileNetV2(
            include_top=False,
            weights=weights,
            input_shape=(*CONFIG["input_size"], 3),
            alpha=float(alpha),
        )

        if freeze_bn:
            for layer in backbone.layers:
                if isinstance(layer, tf.keras.layers.BatchNormalization):
                    layer.trainable = False

        tap_outputs = [backbone.get_layer(n).output for n in tap_layer_names]
        self.feat_extractor = keras.Model(
            backbone.input,
            [backbone.output] + tap_outputs,
            name="student_feature_extractor",
        )

        self.pool = layers.GlobalAveragePooling2D()
        self.drop = layers.Dropout(0.2)
        self.fc = layers.Dense(num_classes, name="student_logits", dtype="float32")

    def call(self, inputs, training=False):
        x = inputs / 127.5 - 1.0
        outs = self.feat_extractor(x, training=training)
        backbone_feat = outs[0]
        taps = outs[1:]
        z = self.pool(backbone_feat)
        z = self.drop(z, training=training)
        logits = self.fc(z)
        return [logits] + list(taps)


class StudentLogitsOnly(tf.keras.Model):
    def __init__(self, student_tap: StudentTapModel):
        super().__init__(name="student_logits_only")
        self.student_tap = student_tap

    def call(self, inputs, training=False):
        return self.student_tap(inputs, training=training)[0]


def build_mobilenetv2_feature_teacher(tap_layer_names):
    weights = "imagenet" if CONFIG["feature_teacher_imagenet_init"] else None
    alpha_try = float(CONFIG["feature_teacher_alpha_try"])

    backbone = None
    for alpha in [alpha_try, 1.0]:
        try:
            backbone = keras.applications.MobileNetV2(
                include_top=False,
                weights=weights,
                input_shape=(*CONFIG["input_size"], 3),
                alpha=float(alpha),
            )
            print(f"Feature Teacher MobileNetV2 Alpha: {alpha}")
            break
        except Exception:
            backbone = None

    if backbone is None:
        backbone = keras.applications.MobileNetV2(
            include_top=False,
            weights=None,
            input_shape=(*CONFIG["input_size"], 3),
            alpha=1.0,
        )
        print("Feature Teacher MobileNetV2 Alpha: 1.0 (No ImageNet Weights)")

    backbone.trainable = False
    tap_outputs = [backbone.get_layer(n).output for n in tap_layer_names]
    extractor = keras.Model(backbone.input, tap_outputs, name="feature_teacher_extractor")

    inputs = keras.Input(shape=(*CONFIG["input_size"], 3))
    x = inputs / 127.5 - 1.0
    taps = extractor(x, training=False)
    return keras.Model(inputs, taps, name="feature_teacher_mobilenetv2_taps")


