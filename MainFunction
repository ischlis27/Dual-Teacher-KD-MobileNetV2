    # ECE table
    ece_rows = []
    for m in METHOD_ORDER:
        eces = np.array([r["ece"] for r in calib_by_method[m]], dtype=np.float32)
        ece_rows.append({"method": METHOD_LABEL[m], "ECE_mean": float(eces.mean()), "ECE_std": float(eces.std(ddof=0))})
