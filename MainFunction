def run_main():
    teacher_logits = train_teacher_once_or_load()

    with STRATEGY.scope():
        tmp_backbone = keras.applications.MobileNetV2(
            include_top=False,
            weights="imagenet" if CONFIG["student_imagenet_init"] else None,
            input_shape=(*CONFIG["input_size"], 3),
            alpha=float(CONFIG["student_alpha"]),
        )
        TAP_NAMES = choose_mobilenetv2_bottleneck_taps(tmp_backbone, CONFIG["tap_mode"], CONFIG["num_taps"])

    print("Selected Bottleneck Taps:", TAP_NAMES)

    with STRATEGY.scope():
        feat_teacher = build_mobilenetv2_feature_teacher(TAP_NAMES)
    describe_model(feat_teacher, "Feature Teacher (MobileNetV2 Taps, Frozen)")

    beta_warmup_epochs = max(1, int(round(CONFIG["student_epochs"] * CONFIG["beta_warmup_frac"])))
    alpha_warmup_epochs = max(1, int(round(CONFIG["student_epochs"] * CONFIG["alpha_warmup_frac"])))

    print(f"Beta Max: {CONFIG['beta_max']} | Warmup epochs: {beta_warmup_epochs}")
    print(f"Alpha Max: {CONFIG['alpha_kd']} | Warmup epochs: {alpha_warmup_epochs}")

    hist = {m: {} for m in METHOD_ORDER}
    times = {m: {} for m in METHOD_ORDER}
    test_rows = []
    calib_by_method = {m: [] for m in METHOD_ORDER}

    rep_models = None

    for seed in CONFIG["seeds"]:
        print("\n" + "#" * 90)
        print(f"Running Experiment (Seed {seed})")
        print("#" * 90)

        set_global_seed(seed)
        train_ds, val_ds, test_ds = make_datasets(run_seed=seed)

        with STRATEGY.scope():
            template_student = StudentTapModel(
                num_classes=CONFIG["num_classes"],
                tap_layer_names=TAP_NAMES,
                imagenet_init=CONFIG["student_imagenet_init"],
                alpha=float(CONFIG["student_alpha"]),
                freeze_bn=CONFIG["freeze_student_bn"],
            )
            _ = template_student(tf.zeros((1, *CONFIG["input_size"], 3), dtype=tf.float32), training=False)
            template_weights = template_student.get_weights()

        def fresh_student():
            st = StudentTapModel(
                num_classes=CONFIG["num_classes"],
                tap_layer_names=TAP_NAMES,
                imagenet_init=CONFIG["student_imagenet_init"],
                alpha=float(CONFIG["student_alpha"]),
                freeze_bn=CONFIG["freeze_student_bn"],
            )
            _ = st(tf.zeros((1, *CONFIG["input_size"], 3), dtype=tf.float32), training=False)
            st.set_weights(template_weights)
            return st

        # ----------------------------
        # Baseline
        # ----------------------------
        print("\n" + "=" * 80)
        print(f"Baseline Training — Seed {seed}")

        with STRATEGY.scope():
            st_b = fresh_student()
            b_logits = StudentLogitsOnly(st_b)
            _ = b_logits(tf.zeros((1, *CONFIG["input_size"], 3), dtype=tf.float32), training=False)
            b_logits.compile(
                optimizer=make_optimizer(),
                loss=ce_loss_fn,
                metrics=[keras.metrics.SparseCategoricalAccuracy(name="acc")],
            )

        b_best = weights_path(f"student_baseline_best_seed{seed}")
        b_time = TimeHistory()
        b_saver = BestStudentSaver(b_logits, b_best, monitor="val_acc", mode="max")

        h_b = b_logits.fit(
            train_ds,
            validation_data=val_ds,
            epochs=CONFIG["student_epochs"],
            callbacks=[b_time, LRLogToHistory(), b_saver],
            verbose=1,
        ).history

        b_logits.load_weights(b_best)
        b_top1, b_top5, b_nll = eval_test_metrics(b_logits, test_ds)

        hist["baseline"][seed] = h_b
        times["baseline"][seed] = b_time.times
        test_rows.append({"seed": seed, "method": "baseline", "top1": b_top1, "top5": b_top5, "nll": b_nll, "best_path": b_best})

        y_true, logits_b = collect_logits_and_labels(b_logits, test_ds)
        probs_b = softmax_np(logits_b)
        ba, bc, bf = reliability_bins(y_true, probs_b, n_bins=CONFIG["ece_bins"])
        calib_by_method["baseline"].append({"seed": seed, "bin_acc": ba, "bin_conf": bc, "bin_frac": bf, "ece": ece_from_bins(ba, bc, bf)})

        # ----------------------------
        # Control (Logits-KD) with alpha warmup
        # ----------------------------
        print("\n" + "=" * 80)
        print(f"Control Training — Seed {seed}")

        with STRATEGY.scope():
            st_c = fresh_student()
            c_logits = StudentLogitsOnly(st_c)
            _ = c_logits(tf.zeros((1, *CONFIG["input_size"], 3), dtype=tf.float32), training=False)

            kd = LogitsKDDistiller(
                student_logits_model=c_logits,
                teacher_logits_model=teacher_logits,
                temperature=CONFIG["temperature"],
                alpha_max=CONFIG["alpha_kd"],
                warmup_epochs=alpha_warmup_epochs,
            )
            kd.compile(optimizer=make_optimizer())

        c_best = weights_path(f"student_control_best_seed{seed}")
        c_time = TimeHistory()
        c_saver = BestStudentSaver(c_logits, c_best, monitor="val_acc", mode="max")

        h_c = kd.fit(
            train_ds,
            validation_data=val_ds,
            epochs=CONFIG["student_epochs"],
            callbacks=[c_time, LRLogToHistory(), EpochSetter(), c_saver],
            verbose=1,
        ).history

        c_logits.load_weights(c_best)
        c_top1, c_top5, c_nll = eval_test_metrics(c_logits, test_ds)

        hist["control"][seed] = h_c
        times["control"][seed] = c_time.times
        test_rows.append({"seed": seed, "method": "control", "top1": c_top1, "top5": c_top5, "nll": c_nll, "best_path": c_best})

        _, logits_c = collect_logits_and_labels(c_logits, test_ds)
        probs_c = softmax_np(logits_c)
        ca, cc, cf = reliability_bins(y_true, probs_c, n_bins=CONFIG["ece_bins"])
        calib_by_method["control"].append({"seed": seed, "bin_acc": ca, "bin_conf": cc, "bin_frac": cf, "ece": ece_from_bins(ca, cc, cf)})

        # ----------------------------
        # Proposed (Dual-Teacher) with alpha + beta warmup
        # ----------------------------
        print("\n" + "=" * 80)
        print(f"Proposed Training — Seed {seed}")

        with STRATEGY.scope():
            st_p = fresh_student()
            prop = DualTeacherBottleneckDistiller(
                student_tap=st_p,
                logits_teacher=teacher_logits,
                feat_teacher_taps=feat_teacher,
                temperature=CONFIG["temperature"],
                alpha_max=CONFIG["alpha_kd"],
                alpha_warmup_epochs=alpha_warmup_epochs,
                beta_max=CONFIG["beta_max"],
                beta_warmup_epochs=beta_warmup_epochs,
                adapters_on=CONFIG["adapters_on"],
                feat_loss_type=CONFIG["feat_loss_type"],
            )
            prop.compile(optimizer=make_optimizer())

        p_best = weights_path(f"student_proposed_best_seed{seed}")
        p_time = TimeHistory()
        p_saver = BestStudentSaver(prop.student_logits, p_best, monitor="val_acc", mode="max")

        h_p = prop.fit(
            train_ds,
            validation_data=val_ds,
            epochs=CONFIG["student_epochs"],
            callbacks=[p_time, LRLogToHistory(), EpochSetter(), p_saver],
            verbose=1,
        ).history

        prop.student_logits.load_weights(p_best)
        p_top1, p_top5, p_nll = eval_test_metrics(prop.student_logits, test_ds)

        hist["proposed"][seed] = h_p
        times["proposed"][seed] = p_time.times
        test_rows.append({"seed": seed, "method": "proposed", "top1": p_top1, "top5": p_top5, "nll": p_nll, "best_path": p_best})

        _, logits_p = collect_logits_and_labels(prop.student_logits, test_ds)
        probs_p = softmax_np(logits_p)
        pa, pc, pf = reliability_bins(y_true, probs_p, n_bins=CONFIG["ece_bins"])
        calib_by_method["proposed"].append({"seed": seed, "bin_acc": pa, "bin_conf": pc, "bin_frac": pf, "ece": ece_from_bins(pa, pc, pf)})

        if rep_models is None and seed == CONFIG["ablation_seed"]:
            rep_models = {
                "teacher": teacher_logits,
                "baseline": b_logits,
                "control": c_logits,
                "proposed": prop.student_logits,
            }

    # ============================
    # Tables
    # ============================
    test_df = pd.DataFrame(test_rows)

    print("\n" + "=" * 90)
    print("Per-Seed Test Results (Best Checkpoints)")
    print("=" * 90)
    print(test_df[["seed", "method", "top1", "top5", "nll", "best_path"]].to_string(index=False))
