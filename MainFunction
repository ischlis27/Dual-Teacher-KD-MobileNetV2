    # ============================
    plot_val_acc_mean_std(hist)
    plot_val_acc_vs_time_mean_std(hist, times)
    plot_test_accuracy_mean_std(test_df)
    plot_calibration_curve_and_print_ece(calib_by_method)

    # ============================
    # Pareto + Latency
    # ============================
    if rep_models is not None:
        top1_mean = test_df.groupby("method")["top1"].mean().to_dict()

        pareto_df = pd.DataFrame([
            {"model": "Baseline (MobileNetV2)", "params": count_params(rep_models["baseline"]), "top1_mean": float(top1_mean["baseline"])},
            {"model": "Control (Logits-KD)", "params": count_params(rep_models["control"]), "top1_mean": float(top1_mean["control"])},
            {"model": "Proposed (KD+Bottleneck)", "params": count_params(rep_models["proposed"]), "top1_mean": float(top1_mean["proposed"])},
        ])
        print("\nPareto Table (Parameters, Top-1 Mean):")
        print(pareto_df.to_string(index=False))
        save_df(pareto_df, "pareto_params_top1_mean")

        plot_model_size_bars(pareto_df)
