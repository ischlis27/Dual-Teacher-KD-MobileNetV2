def plot_ablation_study_bars(ab_df, seed=0):
    desired_order = ["Proposed (Full)", "Proposed (Adapters Off)", "Proposed (Plain MSE)"]
    order = [v for v in desired_order if v in set(ab_df["variant"].tolist())]
    order += [v for v in ab_df["variant"].tolist() if v not in order]
    ab = ab_df.set_index("variant").loc[order].reset_index()

    variants = ab["variant"].tolist()
    x = np.arange(len(variants))
    w = 0.25

    nll = ab["nll"].astype(float).to_numpy()
    nll_score = np.full_like(nll, np.nan, dtype=float)
    finite = np.isfinite(nll)
    if np.any(finite):
        nll_min = np.min(nll[finite])
        nll_max = np.max(nll[finite])
        if abs(nll_max - nll_min) < 1e-12:
            nll_score[finite] = 0.5
        else:
            nll_norm = (nll[finite] - nll_min) / (nll_max - nll_min)
            nll_score[finite] = 1.0 - nll_norm

    plt.figure(figsize=(8, 6))
    plt.bar(x - w, ab["top1"].to_numpy(), width=w, label="Top-1 Accuracy", color=METRIC_COLOR["top1"])
    plt.bar(x, ab["top5"].to_numpy(), width=w, label="Top-5 Accuracy", color=METRIC_COLOR["top5"])

    green_heights = np.nan_to_num(nll_score, nan=0.0)
    green_bars = plt.bar(x + w, green_heights, width=w, label="Normalized NLL Score (Higher Is Better)", color="tab:green")
    for i, ok in enumerate(np.isfinite(nll_score)):
        if not ok:
            green_bars[i].set_alpha(0.0)

    plt.xticks(x, variants, rotation=10)
    plt.ylabel("Score")
    title = f"Ablation Study (Seed {seed}): Accuracy And Normalized NLL"
    plt.title(title)
    plt.legend()
    plt.grid(True, axis="y")
    plt.tight_layout()
    save_current_fig(title)
    plt.show()


def run_ablations(TAP_NAMES, teacher_logits):
    if not CONFIG["run_ablations"]:
        return

    seed = CONFIG["ablation_seed"]
    print("\n" + "=" * 90)
    print(f"Running Ablations (Single Seed {seed}; 20 Epochs Each)")
    print("=" * 90)

    set_global_seed(seed)
    train_ds, val_ds, test_ds = make_datasets(run_seed=seed)

    with STRATEGY.scope():
        feat_teacher = build_mobilenetv2_feature_teacher(TAP_NAMES)

    beta_warmup_epochs = max(1, int(round(CONFIG["student_epochs"] * CONFIG["beta_warmup_frac"])))
    alpha_warmup_epochs = max(1, int(round(CONFIG["student_epochs"] * CONFIG["alpha_warmup_frac"])))

    variants = [
        ("Proposed (Full)", True, "norm_mse"),
        ("Proposed (Adapters Off)", False, "norm_mse"),
        ("Proposed (Plain MSE)", True, "mse"),
    ]

    rows = []
    for tag, adapters_on, feat_loss_type in variants:
        print("\n" + "-" * 80)
        print(f"Ablation Variant: {tag}")

        with STRATEGY.scope():
            st = StudentTapModel(
                num_classes=CONFIG["num_classes"],
                tap_layer_names=TAP_NAMES,
                imagenet_init=CONFIG["student_imagenet_init"],
                alpha=float(CONFIG["student_alpha"]),
                freeze_bn=CONFIG["freeze_student_bn"],
            )
            _ = st(tf.zeros((1, *CONFIG["input_size"], 3), dtype=tf.float32), training=False)

            dist = DualTeacherBottleneckDistiller(
                student_tap=st,
                logits_teacher=teacher_logits,
                feat_teacher_taps=feat_teacher,
                temperature=CONFIG["temperature"],
                alpha_max=CONFIG["alpha_kd"],
                alpha_warmup_epochs=alpha_warmup_epochs,
                beta_max=CONFIG["beta_max"],
                beta_warmup_epochs=beta_warmup_epochs,
                adapters_on=adapters_on,
                feat_loss_type=feat_loss_type,
            )
            dist.compile(optimizer=make_optimizer())

        best_path = weights_path(f"ablation_{slugify(tag)}_best_seed{seed}")
        saver = BestStudentSaver(dist.student_logits, best_path, monitor="val_acc", mode="max")

        dist.fit(
            train_ds,
            validation_data=val_ds,
            epochs=CONFIG["student_epochs"],
            callbacks=[LRLogToHistory(), EpochSetter(), saver],
            verbose=1,
        )

        dist.student_logits.load_weights(best_path)
        top1, top5, nll = eval_test_metrics(dist.student_logits, test_ds)
        rows.append({"variant": tag, "top1": top1, "top5": top5, "nll": nll, "best_path": best_path})

    ab_df = pd.DataFrame(rows)
    print("\n" + "=" * 90)
    print("Ablation Results (Single Seed)")
    print("=" * 90)
    print(ab_df.to_string(index=False))
    save_df(ab_df, "ablation_results")

    plot_ablation_study_bars(ab_df, seed=seed)


