# Part 4 — Losses + Distillers
# =========================================================
ce_loss_fn = keras.losses.SparseCategoricalCrossentropy(from_logits=True)


def kd_kl_loss(teacher_logits, student_logits, temperature: float):
    t = float(temperature)
    p_t = tf.nn.softmax(teacher_logits / t, axis=-1)
    p_s = tf.nn.softmax(student_logits / t, axis=-1)
    kl = tf.keras.losses.KLDivergence()(p_t, p_s)
    return kl * (t ** 2)


def mse_loss(t_feat, s_feat):
    return tf.reduce_mean(tf.square(t_feat - s_feat))


def norm_mse_loss(t_feat, s_feat):
    t = tf.nn.l2_normalize(t_feat, axis=-1)
    s = tf.nn.l2_normalize(s_feat, axis=-1)
    return tf.reduce_mean(tf.square(t - s))


class LogitsKDDistiller(keras.Model):
    def __init__(self, student_logits_model, teacher_logits_model, temperature: float, alpha_max: float, warmup_epochs: int):
        super().__init__(name="logits_kd_distiller")
        self.student = student_logits_model
        self.teacher = teacher_logits_model
        self.temperature = float(temperature)
        self.alpha_max = tf.constant(float(alpha_max), dtype=tf.float32)
        self.warmup_epochs = int(max(1, warmup_epochs))
        self.epoch_var = tf.Variable(0, dtype=tf.int32, trainable=False, name="epoch_var")
        self.acc = keras.metrics.SparseCategoricalAccuracy(name="acc")

    @property
    def metrics(self):
        return [self.acc]

    def compile(self, optimizer):
        super().compile(optimizer=optimizer)
        self.optimizer = optimizer

    def _alpha_t(self):
        e = tf.cast(self.epoch_var + 1, tf.float32)
        w = tf.cast(self.warmup_epochs, tf.float32)
        frac = tf.minimum(1.0, e / w)
        return self.alpha_max * frac

    @tf.function
    def train_step(self, data):
        x, y = data
        t_logits = tf.stop_gradient(self.teacher(x, training=False))
        with tf.GradientTape() as tape:
            s_logits = self.student(x, training=True)
            ce = ce_loss_fn(y, s_logits)
            kd = kd_kl_loss(t_logits, s_logits, self.temperature)
            a = self._alpha_t()
            loss = (1.0 - a) * ce + a * kd
        grads = tape.gradient(loss, self.student.trainable_variables)
        self.optimizer.apply_gradients(zip(grads, self.student.trainable_variables))
        self.acc.update_state(y, tf.nn.softmax(s_logits))
        return {"loss": loss, "acc": self.acc.result(), "ce": ce, "kd": kd, "alpha_t": a}

    @tf.function
    def test_step(self, data):
        x, y = data
        s_logits = self.student(x, training=False)
        nll = ce_loss_fn(y, s_logits)
        self.acc.update_state(y, tf.nn.softmax(s_logits))
        return {"loss": nll, "acc": self.acc.result()}


class DualTeacherBottleneckDistiller(keras.Model):
    def __init__(
        self,
        student_tap: StudentTapModel,
        logits_teacher,
        feat_teacher_taps,
        temperature: float,
        alpha_max: float,
        alpha_warmup_epochs: int,
        beta_max: float,
        beta_warmup_epochs: int,
        adapters_on: bool,
        feat_loss_type: str,
    ):
        super().__init__(name="dual_teacher_bottleneck_distiller")

        self.student_tap = student_tap
        self.student_logits = StudentLogitsOnly(student_tap)

        self.logits_teacher = logits_teacher
        self.feat_teacher = feat_teacher_taps

        self.temperature = float(temperature)

        self.alpha_max = tf.constant(float(alpha_max), dtype=tf.float32)
        self.alpha_warmup_epochs = int(max(1, alpha_warmup_epochs))

        self.beta_max = tf.constant(float(beta_max), dtype=tf.float32)
        self.beta_warmup_epochs = int(max(1, beta_warmup_epochs))

        self.adapters_on = bool(adapters_on)
        self.feat_loss_type = str(feat_loss_type)

        self.epoch_var = tf.Variable(0, dtype=tf.int32, trainable=False, name="epoch_var")

        self.adapters = []
        if self.adapters_on:
            dummy = tf.zeros((1, *CONFIG["input_size"], 3), dtype=tf.float32)
            t_taps = self.feat_teacher(dummy, training=False)
            for i, t in enumerate(t_taps):
                ch = int(t.shape[-1])
                self.adapters.append(layers.Conv2D(ch, 1, padding="same", name=f"adapter_{i}"))

        self.acc = keras.metrics.SparseCategoricalAccuracy(name="acc")
        self._train_vars = None

    @property
    def metrics(self):
        return [self.acc]

    def compile(self, optimizer):
        super().compile(optimizer=optimizer)
        self.optimizer = optimizer

        dummy = tf.zeros((1, *CONFIG["input_size"], 3), dtype=tf.float32)
        s_out = self.student_tap(dummy, training=False)
        _ = self.logits_teacher(dummy, training=False)
        _ = self.feat_teacher(dummy, training=False)

        if self.adapters_on:
            s_feats = s_out[1:]
            for i, ad in enumerate(self.adapters):
                _ = ad(s_feats[i])

        self._train_vars = list(self.student_tap.trainable_variables)
        if self.adapters_on:
            self._train_vars += [v for ad in self.adapters for v in ad.trainable_variables]

        if hasattr(self.optimizer, "build"):
            self.optimizer.build(self._train_vars)

    def _alpha_t(self):
        e = tf.cast(self.epoch_var + 1, tf.float32)
        w = tf.cast(self.alpha_warmup_epochs, tf.float32)
        frac = tf.minimum(1.0, e / w)
        return self.alpha_max * frac

    def _beta_t(self):
        e = tf.cast(self.epoch_var + 1, tf.float32)
        w = tf.cast(self.beta_warmup_epochs, tf.float32)
        frac = tf.minimum(1.0, e / w)
        return self.beta_max * frac

    def _feat_loss(self, t_feat, s_feat):
        if self.feat_loss_type == "mse":
            return mse_loss(t_feat, s_feat)
        return norm_mse_loss(t_feat, s_feat)

    @tf.function
    def train_step(self, data):
        x, y = data
        t_logits = tf.stop_gradient(self.logits_teacher(x, training=False))
        t_feats = [tf.stop_gradient(f) for f in self.feat_teacher(x, training=False)]

        with tf.GradientTape() as tape:
            s_out = self.student_tap(x, training=True)
            s_logits = s_out[0]
            s_feats = s_out[1:]

            ce = ce_loss_fn(y, s_logits)
            kd = kd_kl_loss(t_logits, s_logits, self.temperature)

            feat_losses = []
            for i, (tfm, sfm) in enumerate(zip(t_feats, s_feats)):
                if tf.shape(tfm)[1] != tf.shape(sfm)[1] or tf.shape(tfm)[2] != tf.shape(sfm)[2]:
                    tfm = tf.image.resize(tfm, (tf.shape(sfm)[1], tf.shape(sfm)[2]), method="bilinear")

                sfm_use = sfm
                if self.adapters_on:
                    sfm_use = self.adapters[i](sfm)
                else:
                    ct = tf.shape(tfm)[-1]
                    cs = tf.shape(sfm_use)[-1]
                    cmin = tf.minimum(ct, cs)
                    tfm = tfm[..., :cmin]
                    sfm_use = sfm_use[..., :cmin]

                feat_losses.append(self._feat_loss(tfm, sfm_use))

            feat = tf.add_n(feat_losses) / tf.cast(len(feat_losses), tf.float32)

            a = self._alpha_t()
            b = self._beta_t()
            loss = (1.0 - a) * ce + a * kd + b * feat

        grads = tape.gradient(loss, self._train_vars)
        self.optimizer.apply_gradients(zip(grads, self._train_vars))
        self.acc.update_state(y, tf.nn.softmax(s_logits))
        return {"loss": loss, "acc": self.acc.result(), "ce": ce, "kd": kd, "feat": feat, "alpha_t": a, "beta_t": b}

    @tf.function
    def test_step(self, data):
        x, y = data
        s_logits = self.student_logits(x, training=False)
        nll = ce_loss_fn(y, s_logits)
        self.acc.update_state(y, tf.nn.softmax(s_logits))
        return {"loss": nll, "acc": self.acc.result()}


