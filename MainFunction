def load_cifar100():
    (x_train, y_train), (x_test, y_test) = keras.datasets.cifar100.load_data(label_mode="fine")
    return (x_train, y_train.squeeze().astype(np.int32)), (x_test, y_test.squeeze().astype(np.int32))


def preprocess_and_resize(image, label, training: bool):
    image = tf.cast(image, tf.float32)
    image = tf.image.resize(image, CONFIG["input_size"], method="bilinear")
    if training:
        image = tf.image.random_flip_left_right(image)
        pad = 8
        image = tf.image.resize_with_crop_or_pad(
            image, CONFIG["input_size"][0] + pad, CONFIG["input_size"][1] + pad
        )
        image = tf.image.random_crop(image, size=(CONFIG["input_size"][0], CONFIG["input_size"][1], 3))
    return image, label


_FIXED_SPLIT = None


def make_fixed_split_indices(n, split_seed, val_frac):
    rng = np.random.default_rng(split_seed)
    idx = np.arange(n)
    rng.shuffle(idx)
    val_size = int(val_frac * n)
    trn_idx = idx[val_size:]
    val_idx = idx[:val_size]
    return trn_idx, val_idx


def make_datasets(run_seed: int):
    global _FIXED_SPLIT
    (x_train, y_train), (x_test, y_test) = load_cifar100()

    if _FIXED_SPLIT is None:
        trn_idx, val_idx = make_fixed_split_indices(len(x_train), CONFIG["split_seed"], CONFIG["val_frac"])
        _FIXED_SPLIT = (trn_idx, val_idx)
    else:
        trn_idx, val_idx = _FIXED_SPLIT

    x_trn, y_trn = x_train[trn_idx], y_train[trn_idx]
    x_val, y_val = x_train[val_idx], y_train[val_idx]

    options = tf.data.Options()
    options.experimental_deterministic = False

    def ds_from_numpy(x, y, training: bool):
        ds = tf.data.Dataset.from_tensor_slices((x, y))
        if training:
            ds = ds.shuffle(CONFIG["buffer_size"], seed=run_seed, reshuffle_each_iteration=True)
        ds = ds.map(lambda im, lab: preprocess_and_resize(im, lab, training),
                    num_parallel_calls=tf.data.AUTOTUNE)
        ds = ds.batch(CONFIG["batch_size"], drop_remainder=training).with_options(options)
        ds = ds.prefetch(tf.data.AUTOTUNE)
        return ds

    return ds_from_numpy(x_trn, y_trn, True), ds_from_numpy(x_val, y_val, False), ds_from_numpy(x_test, y_test, False)


