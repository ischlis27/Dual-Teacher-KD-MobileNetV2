def train_teacher_once_or_load():
    t_path = os.path.join(CONFIG["results_dir"], CONFIG["teacher_weights_name"])

    with STRATEGY.scope():
        teacher = build_resnet50_logits_teacher(CONFIG["num_classes"])
        teacher.compile(
            optimizer=make_optimizer(),
            loss=ce_loss_fn,
            metrics=[keras.metrics.SparseCategoricalAccuracy(name="acc")],
        )

    if CONFIG["cache_teacher_weights"] and os.path.exists(t_path):
        try:
            teacher.load_weights(t_path)
            print(f"Loaded Teacher Weights: {t_path}")
            describe_model(teacher, "Teacher (ResNet50 Logits)")
            return teacher
        except Exception:
            try:
                os.remove(t_path)
            except Exception:
                pass

    print("\n" + "=" * 90)
    print("Training The Logits Teacher Once (20 Epochs, Backbone Frozen / Head-Only)")
    print("=" * 90)

    set_global_seed(CONFIG["split_seed"])
    train_ds, val_ds, _ = make_datasets(run_seed=CONFIG["split_seed"])

    saver = keras.callbacks.ModelCheckpoint(
        filepath=t_path,
        monitor="val_acc",
        mode="max",
        save_best_only=True,
        save_weights_only=True,
        verbose=1,
    )

    teacher.fit(
        train_ds,
        validation_data=val_ds,
        epochs=CONFIG["teacher_epochs"],
        callbacks=[LRLogToHistory(), saver],
        verbose=1,
    )

    teacher.load_weights(t_path)
    print(f"Saved Teacher Weights: {t_path}")
    describe_model(teacher, "Teacher (ResNet50 Logits)")
    return teacher


