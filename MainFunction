def eval_test_metrics(student_logits_model, test_ds):
    top1 = keras.metrics.SparseCategoricalAccuracy()
    top5 = keras.metrics.SparseTopKCategoricalAccuracy(k=5)
    nll_sum, n = 0.0, 0
    for x, y in test_ds:
        logits = student_logits_model(x, training=False)
        probs = tf.nn.softmax(logits)
        top1.update_state(y, probs)
        top5.update_state(y, probs)
        nll = ce_loss_fn(y, logits)
        bs = int(y.shape[0])
        nll_sum += float(nll.numpy()) * bs
        n += bs
    return float(top1.result().numpy()), float(top5.result().numpy()), float(nll_sum / max(1, n))


def collect_logits_and_labels(model_logits, ds):
    y_true, logits_all = [], []
    for x, y in ds:
        logits = model_logits(x, training=False)
        y_true.append(y.numpy())
        logits_all.append(logits.numpy())
    return np.concatenate(y_true), np.concatenate(logits_all)


def softmax_np(logits):
    logits = logits - np.max(logits, axis=1, keepdims=True)
    exp = np.exp(logits)
    return exp / np.sum(exp, axis=1, keepdims=True)


def reliability_bins(y_true, probs, n_bins: int):
    preds = np.argmax(probs, axis=1)
    conf = np.max(probs, axis=1)
    acc = (preds == y_true).astype(np.float32)

    bins = np.linspace(0.0, 1.0, n_bins + 1)
    bin_acc, bin_conf, bin_frac = [], [], []

    for i in range(n_bins):
        lo, hi = bins[i], bins[i + 1]
        idx = np.where((conf > lo) & (conf <= hi))[0]
        if len(idx) == 0:
            bin_acc.append(0.0)
            bin_conf.append(0.0)
            bin_frac.append(0.0)
        else:
            bin_acc.append(float(np.mean(acc[idx])))
            bin_conf.append(float(np.mean(conf[idx])))
            bin_frac.append(float(len(idx) / len(y_true)))

    return np.array(bin_acc), np.array(bin_conf), np.array(bin_frac)


def ece_from_bins(bin_acc, bin_conf, bin_frac):
    return float(np.sum(bin_frac * np.abs(bin_acc - bin_conf)))


def count_params(model):
    return int(model.count_params())


def benchmark_latency_ms(model, device_mode: str, batch_size: int, warmup: int, iters: int):
    x = tf.random.uniform((batch_size, *CONFIG["input_size"], 3), dtype=tf.float32)

    @tf.function
    def f(inp):
        return model(inp, training=False)

    dev = "/CPU:0" if device_mode.upper() == "CPU" else None

    if dev is None:
        for _ in range(warmup):
            _ = f(x)
    else:
        with tf.device(dev):
            x_cpu = tf.identity(x)
            for _ in range(warmup):
                _ = f(x_cpu)

    t0 = time.perf_counter()
    if dev is None:
        for _ in range(iters):
            _ = f(x)
    else:
        with tf.device(dev):
            x_cpu = tf.identity(x)
            for _ in range(iters):
                _ = f(x_cpu)
    t1 = time.perf_counter()

    ms_per_iter = (t1 - t0) * 1000.0 / float(iters)
    return float(ms_per_iter / float(batch_size))


